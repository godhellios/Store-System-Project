# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get these from: Supabase → Project Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543, pgbouncer=true)
# Use "Session" mode URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# NEXTAUTH_URL = your production domain (set in Vercel env vars)
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
